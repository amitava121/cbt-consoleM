<Page x:Class="CBT.ExamClient.Views.LoginView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Login">
    
    <Grid Background="{DynamicResource BackgroundBrush}">
        <!-- Centered login card -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="420" Background="{DynamicResource SurfaceBrush}"
                CornerRadius="12" Padding="40,36"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="16" Opacity="0.08" Color="#000000" />
            </Border.Effect>

            <StackPanel>
                <!-- Logo / Title -->
                <TextBlock Text="🎓" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,8" />
                <TextBlock Text="CBT Exam Platform" FontSize="22" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}" />
                <TextBlock Text="Sign in to access your examination" FontSize="13"
                           HorizontalAlignment="Center" Margin="0,6,0,28"
                           Foreground="{DynamicResource SecondaryTextBrush}" />

                <!-- Status indicator -->
                <Border Background="{DynamicResource PrimaryLightBrush}" CornerRadius="6"
                        Padding="12,8" Margin="0,0,0,20">
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" TextAlignment="Center"
                               Foreground="{DynamicResource PrimaryBrush}" />
                </Border>

                <!-- Email -->
                <TextBlock Text="Email Address" FontSize="13" FontWeight="SemiBold"
                           Margin="0,0,0,6" Foreground="{DynamicResource PrimaryTextBrush}" />
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="14" Margin="0,0,0,16"
                         AutomationProperties.Name="Email address" />

                <!-- Password -->
                <TextBlock Text="Password" FontSize="13" FontWeight="SemiBold"
                           Margin="0,0,0,6" Foreground="{DynamicResource PrimaryTextBrush}" />
                <PasswordBox x:Name="PasswordBox" FontSize="14" Margin="0,0,0,8"
                             AutomationProperties.Name="Password" />

                <!-- Error Message -->
                <Border Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"
                        Background="#FDE7E9" CornerRadius="4" Padding="10,8" Margin="0,8,0,0">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#A4262C" FontSize="12"
                               TextWrapping="Wrap" />
                </Border>

                <!-- Login Button -->
                <Button Content="Sign In" Command="{Binding LoginCommand}"
                        Margin="0,20,0,0" Height="42" FontSize="15"
                        HorizontalAlignment="Stretch"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                        AutomationProperties.Name="Sign in button" />

                <!-- Loading -->
                <ProgressBar IsIndeterminate="True" Height="2" Margin="0,12,0,0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
