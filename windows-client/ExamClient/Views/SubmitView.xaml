<Page x:Class="CBT.ExamClient.Views.SubmitView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Submit Exam">
    
    <Grid Background="{DynamicResource BackgroundBrush}">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="500">
            
            <!-- Title -->
            <TextBlock Text="Submit Exam"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"
                       Foreground="{DynamicResource PrimaryTextBrush}" />

            <!-- Summary -->
            <Border Background="{DynamicResource CardBrush}"
                    CornerRadius="8"
                    Padding="24"
                    Margin="0,0,0,30">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Total Questions" FontSize="14" Margin="0,0,0,12" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TotalQuestions}" FontSize="14" FontWeight="SemiBold" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Answered" FontSize="14" Foreground="Green" Margin="0,0,0,12" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AnsweredCount}" FontSize="14" FontWeight="SemiBold" Foreground="Green" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Not Answered" FontSize="14" Foreground="OrangeRed" Margin="0,0,0,12" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding UnansweredCount}" FontSize="14" FontWeight="SemiBold" Foreground="OrangeRed" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Marked for Review" FontSize="14" Foreground="Purple" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding MarkedForReviewCount}" FontSize="14" FontWeight="SemiBold" Foreground="Purple" />
                </Grid>
            </Border>

            <!-- Warning -->
            <TextBlock Text="Are you sure you want to submit? This action cannot be undone."
                       FontSize="13"
                       Foreground="{DynamicResource WarningTextBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"
                       TextWrapping="Wrap" />

            <!-- Status Message -->
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,15"
                       Foreground="{DynamicResource SecondaryTextBrush}" />

            <!-- Buttons -->
            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Go Back"
                        Command="{Binding GoBackCommand}"
                        Height="44"
                        FontSize="15"
                        IsEnabled="{Binding IsSubmitting, Converter={StaticResource InverseBoolConverter}}"
                        AutomationProperties.Name="Go back to exam" />

                <Button Grid.Column="2"
                        Content="Confirm Submit"
                        Command="{Binding ConfirmSubmitCommand}"
                        Height="44"
                        FontSize="15"
                        FontWeight="SemiBold"
                        IsEnabled="{Binding IsSubmitting, Converter={StaticResource InverseBoolConverter}}"
                        AutomationProperties.Name="Confirm exam submission" />
            </Grid>

            <!-- Loading -->
            <ProgressBar IsIndeterminate="True"
                         Height="3"
                         Margin="0,15,0,0"
                         Visibility="{Binding IsSubmitting, Converter={StaticResource BoolToVisibilityConverter}}" />
        </StackPanel>
    </Grid>
</Page>
