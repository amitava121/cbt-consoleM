<Page x:Class="CBT.ExamClient.Views.SubmittedView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Exam Submitted">
    
    <Grid Background="{DynamicResource BackgroundBrush}">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="400">
            <TextBlock Text="✓" FontSize="64" HorizontalAlignment="Center" 
                       Foreground="Green" Margin="0,0,0,20" />
            <TextBlock Text="Exam Submitted Successfully" 
                       FontSize="24" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Margin="0,0,0,15" />
            <TextBlock Text="Your answers have been saved. You may now close this window or wait for your results."
                       FontSize="14" TextWrapping="Wrap" TextAlignment="Center"
                       Foreground="{DynamicResource SecondaryTextBrush}" />
        </StackPanel>
    </Grid>
</Page>
