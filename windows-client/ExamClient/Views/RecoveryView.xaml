<Page x:Class="CBT.ExamClient.Views.RecoveryView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Exam Recovery">
    
    <!-- Recovery screen as specified in CLIENT_ARCHITECTURE.md Section 8.1 -->
    <Grid Background="{DynamicResource BackgroundBrush}">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="450">
            <TextBlock Text="⚠" FontSize="48" HorizontalAlignment="Center" 
                       Foreground="Orange" Margin="0,0,0,20" />
            <TextBlock Text="Exam in Progress" 
                       FontSize="24" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Margin="0,0,0,10" />
            <TextBlock Text="A previous exam session was detected. Please log in to resume your exam."
                       FontSize="14" TextWrapping="Wrap" TextAlignment="Center"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Margin="0,0,0,30" />

            <!-- Pre-filled email from last session -->
            <TextBlock Text="Email" FontSize="14" Margin="0,0,0,5"
                       Foreground="{DynamicResource PrimaryTextBrush}" />
            <TextBox x:Name="RecoveryEmailBox" Padding="10" FontSize="14" Margin="0,0,0,15"
                     AutomationProperties.Name="Email for recovery login" />

            <TextBlock Text="Password" FontSize="14" Margin="0,0,0,5"
                       Foreground="{DynamicResource PrimaryTextBrush}" />
            <PasswordBox x:Name="RecoveryPasswordBox" Padding="10" FontSize="14" Margin="0,0,0,20"
                         AutomationProperties.Name="Password for recovery login" />

            <Button Content="RESUME EXAM" Height="44" FontSize="16" FontWeight="SemiBold"
                    Click="OnResumeClick"
                    AutomationProperties.Name="Resume exam session" />
        </StackPanel>
    </Grid>
</Page>
