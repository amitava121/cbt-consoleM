<Page x:Class="CBT.ExamClient.Views.ExamListView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Assigned Exams"
      Loaded="OnPageLoaded">
    
    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top Header Bar -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="32,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock FontSize="24" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}">
                        <Run Text="Welcome, " />
                        <Run Text="{Binding CandidateName}" FontWeight="Bold" />
                    </TextBlock>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="13" Margin="0,4,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                </StackPanel>

                <!-- Date/Time display -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="CBT Examination Platform" FontSize="12" 
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               HorizontalAlignment="Right" />
                    <TextBlock FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Margin="0,2,0,0">
                        <Run Text="Session Active" />
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="32,24">
            <StackPanel MaxWidth="900" HorizontalAlignment="Left">
                
                <!-- Error Message -->
                <Border Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"
                        Background="#FDE7E9" CornerRadius="6" Padding="16,12" Margin="0,0,0,20"
                        BorderBrush="#F1707A" BorderThickness="1">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#A4262C" FontSize="13" TextWrapping="Wrap" />
                </Border>

                <!-- Section Title -->
                <TextBlock Text="Assigned Examinations" FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,16" />

                <!-- Exam Cards -->
                <ItemsControl ItemsSource="{Binding AssignedExams}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource CardBrush}" CornerRadius="8"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    Margin="0,0,0,16" Padding="0">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.06" Color="#000000" />
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Left accent bar -->
                                    <Border Grid.Column="0" Background="{DynamicResource PrimaryBrush}"
                                            CornerRadius="8,0,0,8" />

                                    <!-- Exam Info -->
                                    <StackPanel Grid.Column="1" Margin="20,18,12,18">
                                        <!-- Title + Status Badge -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="{Binding ExamName}" FontSize="17" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       VerticalAlignment="Center" />
                                            <Border Background="#DFF6DD" CornerRadius="4" Padding="8,3"
                                                    Margin="12,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="#107C10" />
                                            </Border>
                                        </StackPanel>

                                        <!-- Metadata Row -->
                                        <WrapPanel Margin="0,4,0,0">
                                            <!-- Duration -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,24,6">
                                                <TextBlock Text="⏱" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center" />
                                                <TextBlock FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center">
                                                    <Run Text="{Binding DurationMinutes}" />
                                                    <Run Text=" minutes" />
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- Marks -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,24,6">
                                                <TextBlock Text="📝" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center" />
                                                <TextBlock FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center">
                                                    <Run Text="{Binding TotalMarks}" />
                                                    <Run Text=" marks" />
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- Schedule -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6"
                                                        Visibility="{Binding ScheduledAt, Converter={StaticResource NullToVisibilityConverter}}">
                                                <TextBlock Text="📅" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding ScheduledAt}" FontSize="13"
                                                           Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </WrapPanel>
                                    </StackPanel>

                                    <!-- Start Button -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0">
                                        <Button Content="Start Exam →" 
                                                Command="{Binding DataContext.StartExamCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource PrimaryButton}"
                                                Padding="20,10"
                                                FontSize="13"
                                                AutomationProperties.Name="Start this exam" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Loading indicator -->
                <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                            HorizontalAlignment="Center" Margin="0,40,0,0">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="3" />
                    <TextBlock Text="Loading examinations..." FontSize="13" Margin="0,12,0,0"
                               HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" />
                </StackPanel>

                <!-- Starting exam indicator -->
                <Border Visibility="{Binding IsStartingExam, Converter={StaticResource BoolToVisibilityConverter}}"
                        Background="{DynamicResource PrimaryLightBrush}" CornerRadius="8"
                        Padding="20,16" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Text="{Binding StatusMessage}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryBrush}" />
                        <ProgressBar IsIndeterminate="True" Height="3" Margin="0,10,0,0" />
                    </StackPanel>
                </Border>

                <!-- Empty state -->
                <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                            HorizontalAlignment="Center" Margin="0,60,0,0">
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
