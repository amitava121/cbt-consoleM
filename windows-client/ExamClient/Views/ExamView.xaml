<Page x:Class="CBT.ExamClient.Views.ExamView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:CBT.ExamClient.ViewModels"
      Title="Exam">
    
    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>

        <!-- Header Bar -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}" Padding="20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding CurrentSectionName}"
                           VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource HeaderTextBrush}" />

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Ellipse Width="10" Height="10"
                             Fill="{Binding IsOnline, Converter={StaticResource OnlineStatusBrushConverter}}"
                             Margin="0,0,6,0" />
                    <TextBlock Text="{Binding ConnectionStatus}" FontSize="12"
                               Foreground="{DynamicResource HeaderTextBrush}" />
                </StackPanel>

                <Border Grid.Column="3" Background="{DynamicResource TimerBackgroundBrush}"
                        CornerRadius="4" Padding="12,6" VerticalAlignment="Center">
                    <TextBlock Text="{Binding TimerDisplay}" FontSize="20" FontWeight="Bold"
                               FontFamily="Consolas" Foreground="{DynamicResource TimerTextBrush}"
                               AutomationProperties.Name="Remaining time" />
                </Border>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <!-- Question Content Area -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="30">
                <StackPanel>
                    <!-- Question Number + Marks -->
                    <Grid Margin="0,0,0,10">
                        <TextBlock FontSize="14" Foreground="{DynamicResource SecondaryTextBrush}">
                            <Run Text="Question " />
                            <Run Text="{Binding CurrentQuestionIndex, Converter={StaticResource PlusOneConverter}}" />
                            <Run Text=" of " />
                            <Run Text="{Binding TotalQuestions}" />
                        </TextBlock>
                        <TextBlock HorizontalAlignment="Right" FontSize="13"
                                   Foreground="{DynamicResource SecondaryTextBrush}">
                            <Run Text="Marks: +" />
                            <Run Text="{Binding CurrentQuestion.Marks}" />
                            <Run Text=" / -" />
                            <Run Text="{Binding CurrentQuestion.NegativeMarks}" />
                        </TextBlock>
                    </Grid>

                    <!-- Question Text -->
                    <TextBlock Text="{Binding CurrentQuestion.Content.Text}"
                               FontSize="16" TextWrapping="Wrap" Margin="0,0,0,20"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               AutomationProperties.Name="Question text" />

                    <!-- Question Image -->
                    <Image Source="{Binding CurrentQuestionImageSource}" MaxHeight="300"
                           Margin="0,0,0,20" HorizontalAlignment="Left"
                           Visibility="{Binding CurrentQuestion.Content.ImageUrl, Converter={StaticResource NullToVisibilityConverter}}" />

                    <!-- MCQ Single Answer Options -->
                    <ItemsControl ItemsSource="{Binding CurrentQuestion.Options}"
                                  Visibility="{Binding IsMcqSingle, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <RadioButton GroupName="McqOptions" Margin="0,6" Padding="12,10"
                                             FontSize="15" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                             Click="OnMcqOptionClicked"
                                             Tag="{Binding Id}"
                                             AutomationProperties.Name="{Binding Text}">
                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" />
                                </RadioButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- MCQ Multiple Answer Options (CheckBoxes) -->
                    <ItemsControl ItemsSource="{Binding CurrentQuestion.Options}"
                                  Visibility="{Binding IsMcqMultiple, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Margin="0,6" Padding="12,10" FontSize="15"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          Click="OnMcqMultipleOptionClicked"
                                          Tag="{Binding Id}"
                                          AutomationProperties.Name="{Binding Text}">
                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" />
                                </CheckBox>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Fill in the Blank / Essay Text Input -->
                    <StackPanel Visibility="{Binding IsTextInput, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Your Answer:" FontSize="14" Margin="0,0,0,8"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                        <TextBox x:Name="TextAnswerBox"
                                 Text="{Binding TextAnswer, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 MinHeight="120" MaxHeight="400" FontSize="15"
                                 VerticalScrollBarVisibility="Auto"
                                 TextChanged="OnTextAnswerChanged"
                                 AutomationProperties.Name="Text answer input" />
                    </StackPanel>

                    <!-- Numerical Input -->
                    <StackPanel Visibility="{Binding IsNumerical, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Enter numerical answer:" FontSize="14" Margin="0,0,0,8"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                        <TextBox x:Name="NumericalAnswerBox"
                                 Text="{Binding NumericalAnswer, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="18" Width="200" HorizontalAlignment="Left"
                                 TextChanged="OnNumericalAnswerChanged"
                                 AutomationProperties.Name="Numerical answer input" />
                    </StackPanel>

                    <!-- True/False -->
                    <StackPanel Visibility="{Binding IsTrueFalse, Converter={StaticResource BoolToVisibilityConverter}}">
                        <RadioButton GroupName="TrueFalse" Content="True" FontSize="16"
                                     Margin="0,6" Padding="12,10"
                                     Tag="true" Click="OnTrueFalseClicked"
                                     AutomationProperties.Name="True" />
                        <RadioButton GroupName="TrueFalse" Content="False" FontSize="16"
                                     Margin="0,6" Padding="12,10"
                                     Tag="false" Click="OnTrueFalseClicked"
                                     AutomationProperties.Name="False" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Question Palette -->
            <Border Grid.Column="1" Background="{DynamicResource PaletteBrush}"
                    BorderThickness="1,0,0,0" BorderBrush="{DynamicResource BorderBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="15,15,15,10">
                        <TextBlock Text="Question Palette" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10" />
                        <WrapPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                                <Ellipse Width="12" Height="12" Fill="Green" Margin="0,0,4,0" />
                                <TextBlock FontSize="11"><Run Text="{Binding AnsweredCount}" /><Run Text=" Answered" /></TextBlock>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                                <Ellipse Width="12" Height="12" Fill="Gray" Margin="0,0,4,0" />
                                <TextBlock FontSize="11"><Run Text="{Binding UnansweredCount}" /><Run Text=" Unanswered" /></TextBlock>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                                <Ellipse Width="12" Height="12" Fill="Purple" Margin="0,0,4,0" />
                                <TextBlock FontSize="11"><Run Text="{Binding MarkedForReviewCount}" /><Run Text=" Marked" /></TextBlock>
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding QuestionPalette}" Margin="15,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="36" Height="36" Margin="2" FontSize="12"
                                            Content="{Binding QuestionNumber}"
                                            Click="OnPaletteItemClicked" Tag="{Binding QuestionNumber}"
                                            AutomationProperties.Name="Go to question" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Button Grid.Row="2" Content="SUBMIT EXAM" Command="{Binding RequestSubmitCommand}"
                            Margin="15" Height="40" FontWeight="SemiBold"
                            AutomationProperties.Name="Submit exam" />
                </Grid>
            </Border>
        </Grid>

        <!-- Footer Navigation -->
        <Border Grid.Row="2" Background="{DynamicResource FooterBrush}" Padding="20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="← Previous" Command="{Binding PreviousQuestionCommand}"
                        Width="120" Height="34" AutomationProperties.Name="Previous question" />

                <Button Grid.Column="2" Content="Clear Answer" Click="OnClearAnswerClicked"
                        Width="120" Height="34" Margin="0,0,10,0"
                        AutomationProperties.Name="Clear answer" />

                <Button Grid.Column="3" Content="Mark for Review" Command="{Binding MarkForReviewCommand}"
                        Width="140" Height="34" Margin="0,0,10,0"
                        AutomationProperties.Name="Mark for review" />

                <Button Grid.Column="4" Content="Next →" Command="{Binding NextQuestionCommand}"
                        Width="120" Height="34" AutomationProperties.Name="Next question" />
            </Grid>
        </Border>
    </Grid>
</Page>
