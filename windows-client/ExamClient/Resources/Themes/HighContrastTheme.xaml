<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- High Contrast Theme for Accessibility -->
    <!-- CLIENT_ARCHITECTURE.md Section 13: High-contrast mode -->

    <!-- Colors — WCAG AAA contrast ratio (7:1 minimum) -->
    <Color x:Key="PrimaryColor">#FFFF00</Color>
    <Color x:Key="PrimaryDarkColor">#CCCC00</Color>
    <Color x:Key="BackgroundColor">#000000</Color>
    <Color x:Key="CardColor">#1A1A1A</Color>
    <Color x:Key="HeaderColor">#000000</Color>
    <Color x:Key="FooterColor">#1A1A1A</Color>
    <Color x:Key="PaletteColor">#0D0D0D</Color>
    <Color x:Key="BorderColor">#FFFFFF</Color>
    <Color x:Key="PrimaryTextColor">#FFFFFF</Color>
    <Color x:Key="SecondaryTextColor">#CCCCCC</Color>
    <Color x:Key="HeaderTextColor">#FFFF00</Color>
    <Color x:Key="TimerBackgroundColor">#1A1A1A</Color>
    <Color x:Key="TimerTextColor">#FFFF00</Color>
    <Color x:Key="WarningTextColor">#FF6666</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}" />
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}" />
    <SolidColorBrush x:Key="HeaderBrush" Color="{StaticResource HeaderColor}" />
    <SolidColorBrush x:Key="FooterBrush" Color="{StaticResource FooterColor}" />
    <SolidColorBrush x:Key="PaletteBrush" Color="{StaticResource PaletteColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}" />
    <SolidColorBrush x:Key="HeaderTextBrush" Color="{StaticResource HeaderTextColor}" />
    <SolidColorBrush x:Key="TimerBackgroundBrush" Color="{StaticResource TimerBackgroundColor}" />
    <SolidColorBrush x:Key="TimerTextBrush" Color="{StaticResource TimerTextColor}" />
    <SolidColorBrush x:Key="WarningTextBrush" Color="{StaticResource WarningTextColor}" />

</ResourceDictionary>
